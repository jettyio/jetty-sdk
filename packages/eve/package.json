{
  "name": "@jetty/eve",
  "version": "0.3.0",
  "description": "Jetty × eve — an eve extension that live-grades an agent's turns with Jetty, steers a reply-style bandit from the grades, and reports eve evals into Jetty",
  "license": "MIT",
  "type": "module",
  "eve": {
    "extension": {
      "source": "./extension",
      "dist": "./dist/extension"
    }
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.mjs"
    },
    "./reporter": {
      "types": "./dist/reporter/index.d.ts",
      "default": "./dist/reporter/index.js"
    }
  },
  "scripts": {
    "build": "eve extension build && tsc -p tsconfig.reporter.json",
    "prepare": "eve extension build && tsc -p tsconfig.reporter.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.reporter.json --noEmit"
  },
  "dependencies": {
    "@jetty/sdk": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eve": "0.26.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "eve": "*"
  },
  "engines": {
    "node": ">=24"
  }
}
