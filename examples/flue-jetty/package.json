{
  "name": "flue-jetty",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A/B-eval an agent and catch a regression — Flue runs it, Jetty grades it (@jetty/sdk)",
  "scripts": {
    "demo": "tsx src/demo-offline.ts",
    "deploy-grader": "tsx src/deploy-grader.ts",
    "eval": "flue run eval --target node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jetty/sdk": "*",
    "@flue/runtime": "1.0.0-beta.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.1",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": { "node": ">=18" }
}
