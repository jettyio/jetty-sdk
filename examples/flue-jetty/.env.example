# --- Flue (the agent loop) ---
# Anthropic key for the agent's model (pi-ai resolves anthropic/* from this).
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default anthropic/claude-sonnet-4-6)
# FLUE_MODEL=anthropic/claude-sonnet-4-6

# --- Jetty (eval + trajectory store) ---
JETTY_API_TOKEN=mlc_xxxxxxxxxxxxxxxxxxxxxxxx
# Your Jetty collection (the token must have access to it).
JETTY_COLLECTION=your-collection
# The grading runbook the workflow calls (deploy it with: npm run deploy-grader)
JETTY_GRADE_TASK=triage-grader
# Who the Flue-run labels are attributed to.
JETTY_AUTHOR=flue@acme.example
# Grade on Jetty's free trial (10 runs, auto-activated) instead of a pushed key —
# set this and you don't need ANTHROPIC_API_KEY in the collection for grading.
# JETTY_USE_TRIAL_KEYS=true
