# --- eve (the agent loop) ---
# eve resolves models through Vercel AI Gateway by default. For a LOCAL `npx eve dev`
# agent, set ONE of these so the model calls authenticate:
#   AI_GATEWAY_API_KEY=...       # a Vercel AI Gateway key, or
#   VERCEL_OIDC_TOKEN=...        # from `vercel env pull` in a linked project, or
#   OPENROUTER_API_KEY=...       # no AI Gateway? agent/agent.ts then routes the agent
#                                # through OpenRouter directly (bypasses the gateway)
# Optional model override (default anthropic/claude-sonnet-4.6)
# EVE_MODEL=anthropic/claude-sonnet-4.6
# Where the A/B harness reaches the eve agent. `npx eve dev` serves 127.0.0.1:2000.
EVE_URL=http://127.0.0.1:2000
# If you point the harness at a DEPLOYED agent whose HTTP channel requires auth,
# add an authenticator in agent/channels/eve.ts and the matching token here.
# EVE_AUTH_TOKEN=...

# --- Jetty (eval + trajectory store) ---
JETTY_API_TOKEN=mlc_xxxxxxxxxxxxxxxxxxxxxxxx
# Your Jetty collection (the token must have access to it). The hosted eve demo runs on
# jetty-vercel-demo; swap in your own collection if your token can't write to it.
JETTY_COLLECTION=jetty-vercel-demo
# The grading runbook the harness calls (deploy it with: npm run deploy-grader)
JETTY_GRADE_TASK=triage-grader
# Who the eve-run labels are attributed to.
JETTY_AUTHOR=eve@acme.example

# Base URL for the Jetty API. The SDK AND the conference monitor both read this, so
# they hit the same backend. Default is the hosted API; point both at a local mise with
# JETTY_API_URL=http://localhost:8000. JETTY_UI_URL is the deep-link base the monitor uses.
# JETTY_API_URL=https://flows-api.jetty.io
# JETTY_UI_URL=https://jetty.io

# --- Part 2: the live online experiment (eve dev → grade out of band → board) ---
# Task name the live `eve dev` turns are ingested under (the agent's own runs). The
# bandit, deploy-judge, the board, and the monitor all default to this — keep them equal
# or they won't be watching the same runs.
JETTY_AGENT_TASK=triage-live
# grade-watcher poll interval (ms) — how often it looks for ungraded runs.
# GRADE_POLL_MS=3000
# live board (npm run board) port — open http://localhost:4500
# BOARD_PORT=4500

# --- Part 2 (conference monitor): npm run monitor → http://localhost:4600 ---
# The full dashboard folded into this example (monitor/server.mjs): per-dimension verdict
# bars, the bandit's traffic-allocation shifting live, a release gate, and a history strip.
# Zero deps; it self-loads THIS .env, so `npm run monitor` needs no extra setup.
# Keep uncommented lines bare KEY=value — the loader does not strip inline `# comments`.
# MONITOR_PORT falls back to PORT, then 4600.
# MONITOR_PORT=4600
# POLL_MS is how often the monitor polls Jetty.
# POLL_MS=1500
# GATE_MIN_RUNS is judged runs/arm before the gate decides; defaults to BANDIT_MIN_PER_ARM
# so the gate and the bandit arm together.
# GATE_MIN_RUNS=5
# Optional: post one Slack alert per blocked arm when the gate flips to BLOCK.
# SLACK_BOT_TOKEN falls back to SLACK_BOT_OAUTH.
# SLACK_ALERT_CHANNEL=C0XXXXXXX
# SLACK_BOT_TOKEN=xoxb-...
# Rehearsal feeder (npm run feed): how many sample tickets, how far apart (ms),
# and how many times to loop the rotation (FEED_ROUNDS=2 lets the bandit converge).
# FEED_TICKETS=6
# FEED_DELAY_MS=2500
# FEED_ROUNDS=1

# --- Part 2: the bandit (arm selection steered by Jetty grades) ---
# The live agent picks warm/terse per turn by Thompson sampling over the pass-rates
# read back from Jetty labels. It explores 50/50 until EACH arm has
# BANDIT_MIN_PER_ARM judged runs, then exploits. The monitor's release gate arms at the
# same count (GATE_MIN_RUNS defaults to this), so set it once here and both track it.
# JETTY_BANDIT=thompson        # or "off" for the fair coin (controlled 50/50)
# BANDIT_MIN_PER_ARM=5
# BANDIT_WINDOW=60             # most-recent runs whose labels form the posterior
# BANDIT_REFRESH_MS=8000       # how often stats are re-fetched from Jetty

# --- Part 2b: grade with a native simple_judge step (no grade-watcher) ---
# simple_judge is the default demo path (and what `npm start` uses): the eve hook RUNS the
# JETTY_AGENT_TASK (deploy it with `npm run deploy-judge`) per turn and labels its score —
# no grade-watcher. Leave this ACTIVE for the demo. Set it to "ingest" only if you'd rather
# ingest ungraded and grade out of band with `npm run grade-watch`.
JUDGE_MODE=simple_judge
# Judge model + provider (simple_judge routes via LiteLLM; OpenRouter needs no anthropic key).
# JUDGE_MODEL=anthropic/claude-sonnet-4.6
# JUDGE_MODEL_PROVIDER=openrouter
# Grade on Jetty's free trial (10 runs, auto-activated) instead of a pushed key —
# set this and you don't need a provider key in the collection for grading.
# JETTY_USE_TRIAL_KEYS=true
